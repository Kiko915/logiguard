# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Appwrite
# ─────────────────────────────────────────────
APPWRITE_ENDPOINT=https://<REGION>.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=<your-project-id>
APPWRITE_API_KEY=<your-api-key>
APPWRITE_DATABASE_ID=<your-database-id>

# ─────────────────────────────────────────────
# Blockchain (Ganache Local Testnet)
# ─────────────────────────────────────────────
GANACHE_RPC_URL=http://127.0.0.1:8545
GANACHE_CHAIN_ID=1337
BLOCKCHAIN_PRIVATE_KEY=<ganache-account-private-key>
CONTRACT_ADDRESS=<deployed-logiguard-contract-address>

# ─────────────────────────────────────────────
# Simulation Defaults
# ─────────────────────────────────────────────
DEFAULT_ARRIVAL_RATE=500
DEFAULT_SERVICE_RATE=600
DEFAULT_DEFECT_RATE=0.05
DEFAULT_SHIFT_HOURS=12
MONTE_CARLO_REPLICATIONS=1000

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────
# AI Vision — Google Gemini (free tier)
# Get your free key at: https://ai.google.dev
# Free tier: 1,500 requests/day, 15 req/min
# ─────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─────────────────────────────────────────────
# AI Analysis — Groq (optional)
# Powers simulation result interpretation
# Get your free key at: https://console.groq.com
# ─────────────────────────────────────────────
GROQ_API_KEY=gsk_...
