# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_ANON_KEY=<anon-key>

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# ─────────────────────────────────────────────
# Blockchain (Ganache Local Testnet)
# ─────────────────────────────────────────────
GANACHE_RPC_URL=http://127.0.0.1:8545
GANACHE_CHAIN_ID=1337
BLOCKCHAIN_PRIVATE_KEY=<ganache-account-private-key>
CONTRACT_ADDRESS=<deployed-logiguard-contract-address>

# ─────────────────────────────────────────────
# Simulation Defaults
# ─────────────────────────────────────────────
DEFAULT_ARRIVAL_RATE=500
DEFAULT_SERVICE_RATE=600
DEFAULT_DEFECT_RATE=0.05
DEFAULT_SHIFT_HOURS=12
MONTE_CARLO_REPLICATIONS=1000

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
